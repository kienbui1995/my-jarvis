# ============================================================
# MY JARVIS — Environment Configuration
# ============================================================

# --- App ---
APP_NAME=my-jarvis
APP_ENV=development
DEBUG=false
SECRET_KEY=  # REQUIRED: generate with `python -c "import secrets; print(secrets.token_urlsafe(64))"`
DOMAIN=your-domain.com

# --- Database ---
POSTGRES_USER=jarvis
POSTGRES_PASSWORD=  # REQUIRED: strong password
POSTGRES_DB=jarvis
DATABASE_URL=postgresql+asyncpg://${POSTGRES_USER}:${POSTGRES_PASSWORD}@postgres:5432/${POSTGRES_DB}

# --- Redis ---
REDIS_PASSWORD=  # REQUIRED: strong password
REDIS_URL=redis://:${REDIS_PASSWORD}@redis:6379/0

# --- LLM Providers (fill at least GOOGLE_API_KEY for basic usage) ---
GOOGLE_API_KEY=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
DEEPSEEK_API_KEY=

# --- LLM Routing ---
LLM_DEFAULT_MODEL=gemini-2.0-flash
LLM_DAILY_BUDGET_FREE=0.02
LLM_DAILY_BUDGET_PRO=0.10
LLM_DAILY_BUDGET_PRO_PLUS=0.25

# --- Google OAuth ---
GOOGLE_CLIENT_ID=  # From Google Cloud Console → APIs & Services → Credentials

# --- Zalo OA ---
ZALO_OA_ACCESS_TOKEN=
ZALO_OA_SECRET_KEY=

# --- Zalo Bot Platform (bot.zapps.me) ---
ZALO_BOT_TOKEN=  # Bot token from Zalo Bot Manager
ZALO_BOT_SECRET_TOKEN=  # Webhook secret token

# --- Telegram ---
TELEGRAM_BOT_TOKEN=

# --- MinIO ---
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=  # REQUIRED: change from default
MINIO_SECRET_KEY=  # REQUIRED: change from default
MINIO_BUCKET=jarvis

# --- JWT ---
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30

# --- Traefik ---
DOMAIN=localhost
ACME_EMAIL=admin@example.com

# --- Sentry (optional, free tier: sentry.io) ---
SENTRY_DSN=  # Backend: from Sentry → Project Settings → Client Keys (DSN)
NEXT_PUBLIC_SENTRY_DSN=  # Frontend: same or separate Sentry project DSN
